<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .page-hero {
            background: #1a1a1a;
            color: white;
            text-align: center;
            padding: 80px 40px;
        }
        .page-hero h1 { font-size: 42px; font-weight: 300; margin-bottom: 10px; }
        .page-hero p { color: #aaa; font-size: 14px; }
        .shop-content {
            text-align: center;
            padding: 80px 40px;
            color: #666;
        }
        .shop-content h2 { font-size: 28px; font-weight: 300; margin-bottom: 15px; color: #1a1a1a; }
        .back-link { display: inline-block; margin-top: 30px; color: #1a1a1a; font-weight: 600; text-decoration: none; }
    </style>
</head>
<body>

    <nav class="navbar">
        <div class="container-nav">
            <div class="menu-btn">☰ Menu</div>
            <div class="logo">
                <a href="/">
                    <img src="https://uniworthshop.com/cdn/shop/files/LogoSVG_bbf8eed2-7cfd-4bb6-9d51-cac4d718fe55_450x.svg?v=1761913704" alt="Uniworth Logo">
                </a>
            </div>
            <div class="nav-icons">
                <span class="icon">🔍</span>
                <span class="icon">👤</span>
                <span class="icon cart-icon">🛒 <span class="cart-badge">0</span></span>
            </div>
        </div>
    </nav>

    <div class="page-hero">
        <h1>Shop</h1>
        <p>Explore our latest collections</p>
    </div>

    <div class="shop-content">
        <h2>Coming Soon</h2>
        <p>Our full product catalogue is being prepared. Check back soon!</p>
        <a href="/" class="back-link">← Back to Home</a>
    </div>

    <footer class="footer">
        <div class="copyright">
            <p>UNIWORTH DRESS CO. All Rights Reserved. | Privacy Policy</p>
        </div>
    </footer>

</body>
</html>
