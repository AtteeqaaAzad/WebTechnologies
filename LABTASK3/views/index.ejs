<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">

    <!-- Slick Carousel CSS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick-theme.min.css">
</head>
<body>

    <!-- ── TOP BAR ── -->
    <div class="top-bar">
        <div class="container-top">
            <p class="shipping-text">Free Shipping Available Over Rs. 1500 Order.</p>
            <div class="contact-numbers">
                <p>📞 +92 42 325 00940</p>
                <p>💬 +92-345-4037778</p>
            </div>
        </div>
    </div>

    <!-- ── NAVBAR ── -->
    <nav class="navbar">
        <div class="container-nav">
            <div class="menu-btn">☰ Menu</div>
            <div class="logo">
                <a href="/">
                    <img src="https://uniworthshop.com/cdn/shop/files/LogoSVG_bbf8eed2-7cfd-4bb6-9d51-cac4d718fe55_450x.svg?v=1761913704" alt="Uniworth Logo">
                </a>
            </div>
            <div class="nav-icons">
                <span class="icon">🔍</span>
                <a href="/about" class="icon" title="Account">👤</a>
                <span class="icon cart-icon">
                    🛒
                    <span class="cart-badge"><%= cartCount %></span>
                </span>
            </div>
        </div>
    </nav>

    <!-- ── HERO ── -->
    <section class="hero-section">
        <img src="/asset/asset/Slider.jpg1.webp" alt="Hero Background" class="hero-bg">
        <div class="hero-content"></div>
    </section>

    <!-- ── TWO COLUMN ── -->
    <section class="two-column-section">
        <div class="category-item">
            <img src="/asset/asset/row1a_jpg.webp" alt="Polo T-Shirts">
            <div class="category-overlay">
                <p class="shop-label">Shop</p>
                <h2>Polo Shirts</h2>
            </div>
        </div>
        <div class="category-item">
            <img src="/asset/asset/row1b.webp" alt="Casual Shirts">
            <div class="category-overlay">
                <p class="shop-label">Shop</p>
                <h2>Casual Shirts</h2>
            </div>
        </div>
    </section>

    <!-- ── THREE COLUMN ── -->
    <section class="three-column-section">
        <div class="category-item">
            <img src="/asset/asset/ethnic.webp" alt="Ethnic Wear">
            <div class="category-overlay">
                <p class="shop-label">Shop</p>
                <h2>Ethnic</h2>
            </div>
        </div>
        <div class="category-item">
            <img src="/asset/asset/blazers.webp" alt="Blazers">
            <div class="category-overlay">
                <p class="shop-label">Shop</p>
                <h2>Blazers</h2>
            </div>
        </div>
        <div class="category-item">
            <img src="/asset/asset/coord.webp" alt="Co-ord Sets">
            <div class="category-overlay">
                <p class="shop-label">Shop</p>
                <h2>Co-ord sets</h2>
            </div>
        </div>
    </section>

    <!-- ── PRODUCTS CAROUSEL ── -->
    <section class="products-section">
        <div class="product-header">
            <h2 class="tab active">New</h2>
            <span class="separator">/</span>
            <h2 class="tab">Best Seller</h2>
            <span class="separator">/</span>
            <h2 class="tab">Trending</h2>
        </div>

        <div class="slide-counter">
            Showing <span id="current-slide">1</span> of <span id="total-slides">5</span>
        </div>

        <div class="carousel-wrapper">
            <button class="carousel-btn carousel-prev" id="prevBtn">&#8249;</button>

            <div class="products-carousel" id="productsCarousel">
                <div class="product-card">
                    <img src="/asset/asset/prod1.webp" alt="Product 1">
                </div>
                <div class="product-card">
                    <img src="/asset/asset/prod2.webp" alt="Product 2">
                </div>
                <div class="product-card">
                    <img src="/asset/asset/prod3.webp" alt="Product 3">
                </div>
                <div class="product-card">
                    <img src="/asset/asset/prod4.webp" alt="Product 4">
                </div>
                <div class="product-card">
                    <img src="/asset/asset/prod5.webp" alt="Product 5">
                </div>
            </div>

            <button class="carousel-btn carousel-next" id="nextBtn">&#8250;</button>
        </div>
    </section>

    <!-- ── SECOND THREE COLUMN ── -->
    <section class="three-column-section">
        <div class="category-item">
            <img src="/asset/asset/shopcustomized.webp" alt="Customized Stitching">
            <div class="category-overlay">
                <p class="shop-label">Shop</p>
                <h2>Customized<br>Stitching</h2>
            </div>
        </div>
        <div class="category-item">
            <img src="/asset/asset/gurkha.webp" alt="Gurkha Pants">
            <div class="category-overlay">
                <p class="shop-label">Shop</p>
                <h2>Gurkha Pants</h2>
            </div>
        </div>
        <div class="category-item">
            <img src="/asset/asset/black.webp" alt="Uniworth Black">
            <div class="category-overlay">
                <p class="shop-label">Shop</p>
                <h2>Uniworth Black</h2>
            </div>
        </div>
    </section>

    <!-- ── FEATURES ── -->
    <section class="features-section">
        <div class="feature-item">
            <div class="feature-icon">🚚</div>
            <h3>Free Shipping</h3>
        </div>
        <div class="feature-item">
            <div class="feature-icon">🔒</div>
            <h3>Secure Payments</h3>
        </div>
        <div class="feature-item">
            <div class="feature-icon">👑</div>
            <h3>Premium Quality</h3>
        </div>
    </section>

    <!-- ── FOOTER ── -->
    <footer class="footer">
        <div class="footer-main">
            <div class="footer-column about">
                <img src="https://uniworthshop.com/cdn/shop/files/LogoSVG_bbf8eed2-7cfd-4bb6-9d51-cac4d718fe55_450x.svg?v=1761913704" alt="Uniworth Logo" class="footer-logo">
                <p class="company-description">
                    Uniworth is a menswear brand, designed entirely in-house,
                    stand-alone Pakistan's no. 1 Shirt Brand. From timeless
                    tailoring to premium formal shirts, we present a considered
                    edit of quality, wearable clothes, and accessories bearing
                    the Uniworth name.
                </p>
            </div>
            <div class="footer-column">
                <h4>INFORMATION</h4>
                <ul>
                    <li><a href="/about">About Us</a></li>
                    <li><a href="/contact">Contact Us</a></li>
                    <li><a href="#">How To Order</a></li>
                    <li><a href="#">Size Guide</a></li>
                    <li><a href="#">Returns & Exchange Policy</a></li>
                    <li><a href="#">Careers</a></li>
                    <li><a href="#">Blog</a></li>
                </ul>
            </div>
            <div class="footer-column">
                <h4>CUSTOMER SERVICES</h4>
                <ul>
                    <li><a href="#">Shipping Policy</a></li>
                    <li><a href="#">Payment Options</a></li>
                    <li><a href="#">FAQ's</a></li>
                    <li><a href="#">Made To Measure</a></li>
                    <li><a href="#">Made To Measure Stores</a></li>
                    <li><a href="#">Feedback</a></li>
                </ul>
            </div>
            <div class="footer-column">
                <h4>STORE INFORMATION</h4>
                <p>📞 +92 42 325 00940</p>
                <p>💬 +92 345 4037778</p>
                <p>✉️ Askus@Uniworthshop.com</p>
                <p>🕒 Mon-Sat: (10:00AM To 06:00PM)</p>
            </div>
        </div>
        <div class="social-section">
            <div class="social-icons">
                <a href="#" class="social-icon">📘</a>
                <a href="#" class="social-icon">📷</a>
                <a href="#" class="social-icon">🎵</a>
                <a href="#" class="social-icon">▶️</a>
            </div>
        </div>
        <div class="copyright">
            <p>UNIWORTH DRESS CO. All Rights Reserved. | Privacy Policy</p>
        </div>
    </footer>

    <!-- jQuery -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <!-- Slick Carousel JS -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick.min.js"></script>
    <!-- Custom JS -->
    <script src="/js/main.js"></script>

</body>
</html>
