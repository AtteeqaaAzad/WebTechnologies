<% const activePage = isEdit ? '' : 'new'; %>
<%- include('partials/header') %>

<div class="admin-layout">
    <%- include('partials/sidebar') %>

    <main class="admin-main">
        <header class="admin-header">
            <div>
                <h1><%= isEdit ? '✏️ Edit Product' : '➕ Add New Product' %></h1>
                <p class="subtitle">
                    <%= isEdit ? 'Update product details below' : 'Fill in details to add a new product' %>
                </p>
            </div>
            <a href="/admin" class="btn btn-secondary">← Back to Dashboard</a>
        </header>

        <!-- Validation errors -->
        <% if (errors && errors.length > 0) { %>
            <div class="alert alert-error">
                <strong>⚠️ Please fix the following:</strong>
                <ul style="margin-top: 8px; padding-left: 20px;">
                    <% errors.forEach(function(err) { %>
                        <li><%= err %></li>
                    <% }); %>
                </ul>
            </div>
        <% } %>

        <div class="form-card">
            <form
                action="<%= formAction %>"
                method="<%= formMethod %>"
                enctype="multipart/form-data"
                class="product-form"
                id="productForm"
            >
                <div class="form-row">
                    <!-- ─── Left column ─── -->
                    <div class="form-col">
                        <div class="form-group">
                            <label for="name">
                                Product Name <span class="required">*</span>
                            </label>
                            <input
                                type="text"
                                id="name"
                                name="name"
                                value="<%= product ? product.name : '' %>"
                                required
                                minlength="3"
                                maxlength="100"
                                placeholder="e.g., Classic Black Polo Shirt"
                            >
                        </div>

                        <div class="form-group">
                            <label for="category">
                                Category <span class="required">*</span>
                            </label>
                            <select id="category" name="category" required>
                                <option value="">— Select Category —</option>
                                <% const cats = ['Polo Shirts', 'Casual Shirts', 'Ethnic', 'Blazers', 'Co-ord Sets', 'Gurkha Pants', 'Accessories']; %>
                                <% cats.forEach(function(cat) { %>
                                    <option value="<%= cat %>"
                                        <%= product && product.category === cat ? 'selected' : '' %>>
                                        <%= cat %>
                                    </option>
                                <% }); %>
                            </select>
                        </div>

                        <div class="form-group-row">
                            <div class="form-group">
                                <label for="price">
                                    Price (Rs.) <span class="required">*</span>
                                </label>
                                <input
                                    type="number"
                                    id="price"
                                    name="price"
                                    value="<%= product ? product.price : '' %>"
                                    required
                                    min="0"
                                    step="0.01"
                                    placeholder="2499"
                                >
                            </div>

                            <div class="form-group">
                                <label for="stock">
                                    Stock <span class="required">*</span>
                                </label>
                                <input
                                    type="number"
                                    id="stock"
                                    name="stock"
                                    value="<%= product ? product.stock : '' %>"
                                    required
                                    min="0"
                                    placeholder="20"
                                >
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="rating">Rating (0–5)</label>
                            <input
                                type="number"
                                id="rating"
                                name="rating"
                                value="<%= product ? product.rating : '0' %>"
                                min="0"
                                max="5"
                                step="0.1"
                                placeholder="4.5"
                            >
                        </div>

                        <div class="form-group">
                            <label for="description">Description</label>
                            <textarea
                                id="description"
                                name="description"
                                rows="4"
                                placeholder="Brief product description..."
                            ><%= product ? product.description : '' %></textarea>
                        </div>
                    </div>

                    <!-- ─── Right column: image ─── -->
                    <div class="form-col">
                        <div class="form-group">
                            <label for="image">Product Image</label>

                            <% if (isEdit && product && product.image) { %>
                                <div class="current-image">
                                    <p class="image-label">Current image:</p>
                                    <img src="<%= product.image %>" alt="Current product" id="currentImg">
                                </div>
                            <% } %>

                            <div class="image-upload">
                                <input
                                    type="file"
                                    id="image"
                                    name="image"
                                    accept="image/jpeg,image/jpg,image/png,image/webp"
                                    <%= isEdit ? '' : '' %>
                                >
                                <label for="image" class="upload-label">
                                    📁 <span id="uploadText">
                                        <%= isEdit ? 'Replace Image (optional)' : 'Choose Image File' %>
                                    </span>
                                </label>
                            </div>
                            <p class="hint">
                                Accepted: JPG, PNG, WebP, GIF. Max size: 5MB.
                                <% if (!isEdit) { %>
                                    <br>If no image is uploaded, a default placeholder is used.
                                <% } %>
                            </p>

                            <!-- Live preview -->
                            <div id="imagePreview" class="image-preview" style="display: none;">
                                <p class="image-label">Preview:</p>
                                <img id="previewImg" src="" alt="Preview">
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ─── Actions ─── -->
                <div class="form-actions">
                    <a href="/admin" class="btn btn-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary">
                        <%= isEdit ? '💾 Save Changes' : '✅ Create Product' %>
                    </button>
                </div>
            </form>
        </div>
    </main>
</div>

<script>
    // ─── Live image preview ───
    const imageInput = document.getElementById('image');
    const imagePreview = document.getElementById('imagePreview');
    const previewImg = document.getElementById('previewImg');
    const uploadText = document.getElementById('uploadText');

    if (imageInput) {
        imageInput.addEventListener('change', function (e) {
            const file = e.target.files[0];
            if (file) {
                uploadText.textContent = file.name;
                const reader = new FileReader();
                reader.onload = function (ev) {
                    previewImg.src = ev.target.result;
                    imagePreview.style.display = 'block';
                };
                reader.readAsDataURL(file);
            }
        });
    }

    // ─── Client-side validation reinforcement ───
    document.getElementById('productForm').addEventListener('submit', function (e) {
        const name = document.getElementById('name').value.trim();
        const price = document.getElementById('price').value;
        const category = document.getElementById('category').value;
        const stock = document.getElementById('stock').value;

        if (!name || !price || !category || stock === '') {
            e.preventDefault();
            alert('⚠️ Please fill in all required fields marked with *');
            return;
        }

        if (parseFloat(price) < 0) {
            e.preventDefault();
            alert('⚠️ Price cannot be negative.');
            return;
        }

        if (parseInt(stock) < 0) {
            e.preventDefault();
            alert('⚠️ Stock cannot be negative.');
            return;
        }
    });
</script>

<%- include('partials/footer') %>
