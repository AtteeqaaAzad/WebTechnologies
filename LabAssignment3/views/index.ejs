<%- include('partials/header') %>
<%- include('partials/navbar') %>
<%- include('partials/flash') %>

<!-- ============================================
     HERO SECTION
     ============================================ -->
<section class="hero-section">
    <img src="/asset/Slider.jpg1.webp" alt="Hero Background" class="hero-bg">
    <div class="hero-content"></div>
</section>

<!-- ============================================
     TWO-COLUMN CATEGORIES
     ============================================ -->
<section class="two-column-section">
    <div class="category-item">
        <img src="/asset/row1a_jpg.webp" alt="Polo T-Shirts">
        <div class="category-overlay">
            <p class="shop-label">Shop</p>
            <h2>Polo Shirts</h2>
        </div>
    </div>
    <div class="category-item">
        <img src="/asset/row1b.webp" alt="Casual Shirts">
        <div class="category-overlay">
            <p class="shop-label">Shop</p>
            <h2>Casual Shirts</h2>
        </div>
    </div>
</section>

<!-- ============================================
     THREE-COLUMN CATEGORIES (1)
     ============================================ -->
<section class="three-column-section">
    <% const categories1 = [
        { img: 'ethnic.webp', alt: 'Ethnic Wear', title: 'Ethnic' },
        { img: 'blazers.webp', alt: 'Blazers', title: 'Blazers' },
        { img: 'coord.webp', alt: 'Co-ord Sets', title: 'Co-ord sets' }
    ]; %>
    <% categories1.forEach(function(cat) { %>
        <div class="category-item">
            <img src="/asset/<%= cat.img %>" alt="<%= cat.alt %>">
            <div class="category-overlay">
                <p class="shop-label">Shop</p>
                <h2><%= cat.title %></h2>
            </div>
        </div>
    <% }); %>
</section>

<!-- ============================================
     PRODUCTS CAROUSEL
     ============================================ -->
<section class="products-section">
    <div class="product-header">
        <h2 class="tab active">New</h2>
        <span class="separator">/</span>
        <h2 class="tab">Best Seller</h2>
        <span class="separator">/</span>
        <h2 class="tab">Trending</h2>
    </div>

    <!-- Slide Counter -->
    <div class="slide-counter">
        Showing <span id="current-slide">1</span> of <span id="total-slides">5</span>
    </div>

    <!-- Carousel Wrapper -->
    <div class="carousel-wrapper">
        <button class="carousel-btn carousel-prev" id="prevBtn">&#8249;</button>

        <!-- Carousel Track — products generated by EJS loop -->
        <div class="products-carousel" id="productsCarousel">
            <% for (let i = 1; i <= 5; i++) { %>
                <div class="product-card">
                    <img src="/asset/prod<%= i %>.webp" alt="Product <%= i %>">
                </div>
            <% } %>
        </div>

        <button class="carousel-btn carousel-next" id="nextBtn">&#8250;</button>
    </div>
</section>

<!-- ============================================
     THREE-COLUMN CATEGORIES (2)
     ============================================ -->
<section class="three-column-section">
    <% const categories2 = [
        { img: 'shopcustomized.webp', alt: 'Customized Stitching', title: 'Customized<br>Stitching' },
        { img: 'gurkha.webp', alt: 'Gurkha Pants', title: 'Gurkha Pants' },
        { img: 'black.webp', alt: 'Uniworth Black', title: 'Uniworth Black' }
    ]; %>
    <% categories2.forEach(function(cat) { %>
        <div class="category-item">
            <img src="/asset/<%= cat.img %>" alt="<%= cat.alt %>">
            <div class="category-overlay">
                <p class="shop-label">Shop</p>
                <h2><%- cat.title %></h2>
            </div>
        </div>
    <% }); %>
</section>

<!-- ============================================
     FEATURES
     ============================================ -->
<section class="features-section">
    <% const features = [
        { icon: '🚚', title: 'Free Shipping' },
        { icon: '🔒', title: 'Secure Payments' },
        { icon: '👑', title: 'Premium Quality' }
    ]; %>
    <% features.forEach(function(feature) { %>
        <div class="feature-item">
            <div class="feature-icon"><%= feature.icon %></div>
            <h3><%= feature.title %></h3>
        </div>
    <% }); %>
</section>

<%- include('partials/footer') %>
