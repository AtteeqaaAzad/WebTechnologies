<aside class="admin-sidebar">
    <div class="sidebar-brand">
        <h2>UNIWORTH</h2>
        <p>Admin Panel</p>
    </div>

    <% if (currentUser) { %>
        <div class="sidebar-user">
            <div class="sidebar-avatar"><%= currentUser.name.charAt(0).toUpperCase() %></div>
            <div>
                <p class="sidebar-username"><%= currentUser.name %></p>
                <p class="sidebar-role">🛡️ <%= currentUser.role %></p>
            </div>
        </div>
    <% } %>

    <nav class="sidebar-nav">
        <a href="/admin" class="sidebar-link <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active' : '' %>">
            📊 <span>Dashboard</span>
        </a>
        <a href="/admin/products/new" class="sidebar-link <%= typeof activePage !== 'undefined' && activePage === 'new' ? 'active' : '' %>">
            ➕ <span>Add Product</span>
        </a>
        <a href="/products" target="_blank" class="sidebar-link">
            🌐 <span>View Store</span>
        </a>
        <a href="/auth/profile" class="sidebar-link">
            👤 <span>My Profile</span>
        </a>
    </nav>

    <div class="sidebar-footer">
        <a href="/auth/logout" class="logout-btn">
            🚪 Logout
        </a>
    </div>
</aside>
