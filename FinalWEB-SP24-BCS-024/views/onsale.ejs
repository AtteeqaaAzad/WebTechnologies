<!-- views/onsale.ejs -->
<div class="container" style="padding: 30px;">

  <h1 style="text-align:center; margin-bottom: 30px;">🔥 On Sale Products</h1>

  <!-- All products go here — jQuery will show/hide them -->
  <div id="product-list" style="display: flex; flex-wrap: wrap; gap: 20px; justify-content: center;">

    <% products.forEach(function(product) { %>
      <div class="product-card" style="
        border: 1px solid #ddd;
        border-radius: 8px;
        padding: 15px;
        width: 200px;
        text-align: center;
        background: #fff;
        box-shadow: 0 2px 6px rgba(0,0,0,0.1);
      ">
        <img src="<%= product.image || '/images/placeholder.png' %>"
             alt="<%= product.name %>"
             style="width:100%; height:150px; object-fit:cover; border-radius:5px;">
        <h4 style="margin: 10px 0 5px;"><%= product.name %></h4>
        <p style="color: green; font-weight: bold;">Rs. <%= product.price %></p>
        <span style="background:red; color:white; padding:3px 8px; border-radius:4px; font-size:12px;">ON SALE</span>
      </div>
    <% }) %>

  </div>

  <!-- Pagination Controls -->
  <div style="text-align:center; margin-top: 40px;">
    <button id="prevBtn" style="
      padding: 10px 25px;
      margin: 0 10px;
      background: #333;
      color: white;
      border: none;
      border-radius: 5px;
      cursor: pointer;
      font-size: 16px;
    ">← Previous</button>

    <span id="pageInfo" style="font-size: 18px; font-weight: bold;"></span>

    <button id="nextBtn" style="
      padding: 10px 25px;
      margin: 0 10px;
      background: #333;
      color: white;
      border: none;
      border-radius: 5px;
      cursor: pointer;
      font-size: 16px;
    ">Next →</button>
  </div>

</div>

<!-- jQuery CDN -->
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

<script>
$(document).ready(function() {

  var perPage    = 10;
  var currentPage = 1;

  // Get all product cards
  var allCards = $('.product-card');
  var totalCards = allCards.length;
  var totalPages = Math.ceil(totalCards / perPage);

  // Function to show the correct 10 products
  function showPage(page) {
    // Hide all cards first
    allCards.hide();

    // Calculate which cards to show
    var start = (page - 1) * perPage;  // e.g. page 1 = index 0
    var end   = start + perPage;        // e.g. page 1 = index 10

    // Show only the slice for this page
    allCards.slice(start, end).show();

    // Update the page indicator text
    $('#pageInfo').text('Page ' + page + ' of ' + totalPages);

    // Disable Prev button on first page
    if (page === 1) {
      $('#prevBtn').prop('disabled', true).css('opacity', '0.4');
    } else {
      $('#prevBtn').prop('disabled', false).css('opacity', '1');
    }

    // Disable Next button on last page
    if (page === totalPages) {
      $('#nextBtn').prop('disabled', true).css('opacity', '0.4');
    } else {
      $('#nextBtn').prop('disabled', false).css('opacity', '1');
    }
  }

  // Show page 1 on load
  showPage(currentPage);

  // Next button clicked
  $('#nextBtn').click(function() {
    if (currentPage < totalPages) {
      currentPage++;
      showPage(currentPage);
    }
  });

  // Previous button clicked
  $('#prevBtn').click(function() {
    if (currentPage > 1) {
      currentPage--;
      showPage(currentPage);
    }
  });

});
</script>