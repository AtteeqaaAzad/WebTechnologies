<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>

<section class="auth-page">
    <div class="auth-container">
        <div class="auth-header">
            <h1>Sign In</h1>
            <p>Welcome back to Uniworth</p>
        </div>

        <form action="/auth/login" method="POST" class="auth-form">
            <div class="form-group">
                <label for="email">Email Address</label>
                <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    placeholder="you@example.com"
                    autofocus
                >
            </div>

            <div class="form-group">
                <label for="password">Password</label>
                <input
                    type="password"
                    id="password"
                    name="password"
                    required
                    placeholder="Your password"
                    minlength="6"
                >
            </div>

            <button type="submit" class="auth-btn">Sign In</button>

            <p class="auth-link">
                Don't have an account? <a href="/auth/register">Create one</a>
            </p>
        </form>

        <div class="auth-hint">
            <p>🔑 <strong>Demo accounts:</strong></p>
            <p>Admin: <code>admin@uniworth.com</code> / <code>admin123</code></p>
            <p>Customer: <code>customer@uniworth.com</code> / <code>customer123</code></p>
        </div>
    </div>
</section>

<%- include('../partials/footer') %>
